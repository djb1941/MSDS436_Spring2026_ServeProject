# Database Configuration
POSTGRES_USER=robotics_user
POSTGRES_PASSWORD=robotics_password
POSTGRES_DB=serve_robotics
DATABASE_URL=postgresql://robotics_user:robotics_password@postgres:5432/serve_robotics

# Application Configuration
PYTHONUNBUFFERED=1
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Simulation Configuration
SIMULATION_START_HOUR=8
SIMULATION_END_HOUR=20
NUM_ROBOTS=5
DELIVERY_SERVICE_AREA=Glendale,CA
